From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Mon, 27 Apr 2026 01:23:36 -0500
Subject: [PATCH 48/70] winewayland: Fix a TRACE message in keyboard.

---
 dlls/winewayland.drv/wayland_keyboard.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/dlls/winewayland.drv/wayland_keyboard.c b/dlls/winewayland.drv/wayland_keyboard.c
index 869248d32da..fcf8f9c2aa6 100644
--- a/dlls/winewayland.drv/wayland_keyboard.c
+++ b/dlls/winewayland.drv/wayland_keyboard.c
@@ -1106,7 +1106,7 @@ static void keyboard_handle_modifiers(void *data, struct wl_keyboard *wl_keyboar
 
     if (!wayland_keyboard_get_focused_hwnd()) return;
 
-    TRACE("serial=%u mods_depressed=%#x mods_latched=%#x mods_locked=%#x xkb_group=%d stub!\n",
+    TRACE("serial=%u mods_depressed=%#x mods_latched=%#x mods_locked=%#x xkb_group=%d\n",
           serial, mods_depressed, mods_latched, mods_locked, xkb_group);
 
     pthread_mutex_lock(&keyboard->mutex);
