From 3b3a3565381a200b3bcfc18ee63d893753ad21c7 Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Mon, 18 May 2026 18:14:53 +0200
Subject: [PATCH 65/65] win32u: Track swapchain/opengl reference of client
 surface.

---
 dlls/win32u/opengl.c          | 12 ++++++++++--
 dlls/win32u/vulkan.c          |  5 +++--
 dlls/winewayland.drv/vulkan.c |  3 +--
 include/wine/gdi_driver.h     |  1 +
 4 files changed, 15 insertions(+), 6 deletions(-)

diff --git a/dlls/win32u/opengl.c b/dlls/win32u/opengl.c
index 3b8db3ca291..864516fd761 100644
--- a/dlls/win32u/opengl.c
+++ b/dlls/win32u/opengl.c
@@ -110,7 +110,11 @@ void *opengl_drawable_create( UINT size, const struct opengl_drawable_funcs *fun
     drawable->interval = INT_MIN;
     drawable->doublebuffer = !!(pixel_formats[format - 1].pfd.dwFlags & PFD_DOUBLEBUFFER);
     drawable->stereo = !!(pixel_formats[format - 1].pfd.dwFlags & PFD_STEREO);
-    if ((drawable->client = client)) client_surface_add_ref( client );
+    if ((drawable->client = client))
+    {
+        client_surface_add_ref( client );
+        InterlockedIncrement( &client->busy_ref );
+    }
 
     opengl_drawable_map_buffer( drawable, GL_FRONT_LEFT, GL_FRONT_LEFT );
     opengl_drawable_map_buffer( drawable, GL_FRONT, GL_FRONT );
@@ -151,7 +155,11 @@ void opengl_drawable_release( struct opengl_drawable *drawable )
 
         drawable->funcs->destroy( drawable );
         if (drawable->surface) funcs->p_eglDestroySurface( egl->display, drawable->surface );
-        if (drawable->client) client_surface_release( drawable->client );
+        if (drawable->client)
+        {
+            InterlockedDecrement( &drawable->client->busy_ref );
+            client_surface_release( drawable->client );
+        }
         free( drawable );
     }
 }
diff --git a/dlls/win32u/vulkan.c b/dlls/win32u/vulkan.c
index b3c4346ed83..64de01dbe4a 100644
--- a/dlls/win32u/vulkan.c
+++ b/dlls/win32u/vulkan.c
@@ -1857,7 +1857,6 @@ static VkResult win32u_vkCreateSwapchainKHR( VkDevice client_device, const VkSwa
 
     if (!(swapchain = calloc( 1, sizeof(*swapchain) ))) return VK_ERROR_OUT_OF_HOST_MEMORY;
 
-
     if (driver_funcs->p_vulkan_surface_configure &&
         (res = driver_funcs->p_vulkan_surface_configure( &create_info_host.imageColorSpace, create_info_host.compositeAlpha, surface->client )))
     {
@@ -1865,10 +1864,11 @@ static VkResult win32u_vkCreateSwapchainKHR( VkDevice client_device, const VkSwa
         return res;
     }
 
-
+    InterlockedIncrement( &surface->client->busy_ref );
 
     if ((res = device->p_vkCreateSwapchainKHR( device->host.device, &create_info_host, NULL, &host_swapchain )))
     {
+        InterlockedDecrement( &surface->client->busy_ref );
         free( swapchain );
         return res;
     }
@@ -1898,6 +1898,7 @@ void win32u_vkDestroySwapchainKHR( VkDevice client_device, VkSwapchainKHR client
     if (swapchain->surface)
     {
         swapchain->surface->swapchain = NULL;
+        InterlockedDecrement( &swapchain->surface->client->busy_ref );
         client_surface_release( swapchain->surface->client );
     }
     instance->p_remove_object( instance, &swapchain->obj.obj );
diff --git a/dlls/winewayland.drv/vulkan.c b/dlls/winewayland.drv/vulkan.c
index 67c65f63acd..8fd342a196d 100644
--- a/dlls/winewayland.drv/vulkan.c
+++ b/dlls/winewayland.drv/vulkan.c
@@ -59,8 +59,7 @@ static struct wayland_client_surface *find_client_surface(HWND hwnd)
     LIST_FOR_EACH_ENTRY(surface, &data->client_surface_cache,
                         struct wayland_client_surface, entry)
     {
-        /* this is held by a swapchain */
-        if (surface->client.ref > 1) continue;
+        if (ReadAcquire( &surface->client.busy_ref )) continue;
 
         list_remove(&surface->entry);
 
diff --git a/include/wine/gdi_driver.h b/include/wine/gdi_driver.h
index c0c2d2a008a..feee25d5ed4 100644
--- a/include/wine/gdi_driver.h
+++ b/include/wine/gdi_driver.h
@@ -263,6 +263,7 @@ struct client_surface
     const struct client_surface_funcs *funcs;
     struct list                        entry;          /* entry in win32u managed list */
     LONG                               ref;            /* reference count */
+    LONG                               busy_ref;       /* count of drawables/swapchains referencing this surface */
     HWND                               hwnd;           /* window the surface was created for */
     LONG                               updated;        /* has been moved / resized / reparented */
     LONG                               offscreen;      /* client window is offscreen */
-- 
