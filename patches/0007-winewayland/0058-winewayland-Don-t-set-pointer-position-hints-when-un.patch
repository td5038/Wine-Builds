From 00e461c97b92f0c7301d8af17443ffd72d13b7b8 Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Tue, 5 May 2026 05:42:14 -0500
Subject: [PATCH 58/65] winewayland: Don't set pointer position hints when
 unnecessary.

(cherry picked from commit cc4d66624dce089a326a190eb58c06d2f26db853)
---
 dlls/winewayland.drv/wayland_pointer.c | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/dlls/winewayland.drv/wayland_pointer.c b/dlls/winewayland.drv/wayland_pointer.c
index e6bb0d0e8f6..ce5c6c23332 100644
--- a/dlls/winewayland.drv/wayland_pointer.c
+++ b/dlls/winewayland.drv/wayland_pointer.c
@@ -1242,7 +1242,11 @@ BOOL WAYLAND_ClipCursor(const RECT *clip, BOOL reset)
         pointer->pending_warp = FALSE;
     }
 
-    if (wl_surface && hwnd == pointer->constraint_hwnd && pointer->zwp_locked_pointer_v1)
+    /* according to protocol spec, the position hints only do something
+     * when transitioning from locked to unlocked states */
+    if (wl_surface && hwnd == pointer->constraint_hwnd &&
+        pointer->zwp_locked_pointer_v1 &&
+        (pointer->cursor.wl_surface || pointer->wp_cursor_shape_device_v1))
     {
         zwp_locked_pointer_v1_set_cursor_position_hint(
                 pointer->zwp_locked_pointer_v1,
-- 
2.54.0

