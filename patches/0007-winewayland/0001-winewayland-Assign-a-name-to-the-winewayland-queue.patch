From 681cc902cc70eaab26d0287c8307e6251ea76403 Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Thu, 16 Apr 2026 23:47:13 -0500
Subject: [PATCH 01/65] winewayland: Assign a name to the winewayland queue.

---
 dlls/winewayland.drv/wayland.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/dlls/winewayland.drv/wayland.c b/dlls/winewayland.drv/wayland.c
index b3d6b3c89e7..6213576e1ce 100644
--- a/dlls/winewayland.drv/wayland.c
+++ b/dlls/winewayland.drv/wayland.c
@@ -260,7 +260,8 @@ BOOL wayland_process_init(void)
 
     TRACE("wl_display=%p\n", process_wayland.wl_display);
 
-    if (!(process_wayland.wl_event_queue = wl_display_create_queue(process_wayland.wl_display)))
+    if (!(process_wayland.wl_event_queue =
+          wl_display_create_queue_with_name(process_wayland.wl_display, "winewayland")))
     {
         ERR("Failed to create event queue\n");
         return FALSE;
